# ----------------------------------------------------------------------------
# Instructor Lifecycle CRM — environment template
# Copy to `.env` and fill in. Nothing here is required to run locally:
# if MONGODB_URI is unset, the app boots an in-memory MongoDB for development.
# ----------------------------------------------------------------------------

# MongoDB connection string (e.g. MongoDB Atlas). Leave blank for local in-memory DB.
MONGODB_URI=

# Secret used to sign session JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Public base URL (used in email links). Defaults to http://localhost:3000.
APP_URL=http://localhost:3000

# ---- Email (AWS SES) — optional. Without these, emails are logged, not sent. ----
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=no-reply@yourdomain.com

# Seed admin (used by `npm run seed`)
SEED_ADMIN_EMAIL=ops@org.in
SEED_ADMIN_PASSWORD=password

# Encryption-at-rest for sensitive fields (optional). 64-char hex or any long
# string. If unset, sensitive values are stored as plaintext.
ENCRYPTION_KEY=

# Secret the scheduler sends (header x-cron-secret or ?secret=) to trigger
# /api/cron/reminders. Required for external cron; Ops Admins can also run it in-app.
CRON_SECRET=

# Data-retention window in days for exited instructors (npm run retention).
RETENTION_DAYS=1095

# ---- Google sign-in (optional) — from Google Cloud Console OAuth client ----
# Authorized redirect URI must be: <APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Override only if your callback URL differs from APP_URL + /api/auth/google/callback
GOOGLE_REDIRECT_URI=
