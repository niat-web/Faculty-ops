# Copy to server/.env and fill in. Reuse the same Atlas URI as the Next app.
# e.g. mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=
JWT_SECRET=change-me-to-a-long-random-string
PORT=4000
# Where the React client runs (for CORS + cookies). Comma-separate multiples.
CLIENT_URL=http://localhost:5173
# Public base URL of the client app — used in emailed links (set-password etc.)
APP_URL=http://localhost:5173

# Email (AWS SES) — optional; without it, emails log to the console
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
SES_FROM_EMAIL=no-reply@yourdomain.com

# Google sign-in — optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Security / ops — optional
ENCRYPTION_KEY=
CRON_SECRET=
RETENTION_DAYS=1095

# Dashboard AI assistant (Groq) — optional; without GROQ_API_KEY the assistant shows a "not configured"
# message. Create a key at https://console.groq.com/keys. Model defaults to llama-3.3-70b-versatile.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Seed admin (used only by a seed script)
SEED_ADMIN_EMAIL=ops@org.in
SEED_ADMIN_PASSWORD=password
